# Copy to configs/ai-stack/.env or /srv/ai/compose/core/.env and replace every value.
TZ=America/Sao_Paulo

# Image tags. Pin exact tags or digests after first validation.
OLLAMA_TAG=latest
OPEN_WEBUI_TAG=main
QDRANT_TAG=latest
NEO4J_TAG=2026.04.0
JUPYTER_BASE_TAG=2026-05-11
UV_VERSION=latest

# Secrets. Replace with random values; never commit real secrets.
WEBUI_SECRET_KEY=${REPLACE_WITH_RANDOM_HEX}
QDRANT_API_KEY=${REPLACE_WITH_RANDOM_HEX}
NEO4J_AUTH=neo4j/${REPLACE_WITH_STRONG_PASSWORD}
JUPYTER_TOKEN=${REPLACE_WITH_RANDOM_TOKEN}
